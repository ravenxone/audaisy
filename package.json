{
  "name": "audaisy",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace apps/desktop",
    "lint": "npm run lint --workspace apps/desktop",
    "test": "npm run test:desktop && npm run test:runtime",
    "test:desktop": "npm run test --workspace apps/desktop",
    "test:runtime": "python3 -m pytest apps/runtime/tests"
  }
}
