{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audaisy",
  "version": "0.1.0",
  "identifier": "app.audaisy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Audaisy",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "app"
  }
}
